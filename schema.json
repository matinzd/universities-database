{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Universities Database",
  "type": "object",
  "required": ["universities"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "universities": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/university"
      }
    }
  },
  "definitions": {
    "university": {
      "type": "object",
      "required": ["name", "country", "domains"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Official English name of the university"
        },
        "name_local": {
          "type": "string",
          "description": "Official name of the university in its local language"
        },
        "country": {
          "type": "string",
          "pattern": "^[A-Z]{2}$",
          "description": "ISO 3166-1 alpha-2 country code (e.g. IR, US, GB)"
        },
        "domains": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9.-]*\\.[a-z]{2,}$",
            "description": "Email domain (e.g. ut.ac.ir, mit.edu, ox.ac.uk)"
          },
          "description": "List of email domains used by this university"
        },
        "type": {
          "type": "string",
          "enum": ["public", "private", "islamic-azad", "medical", "distance", "applied-science", ""],
          "description": "Institution type"
        },
        "city": {
          "type": "string",
          "description": "City of the main campus"
        },
        "website": {
          "type": "string",
          "description": "Official website URL"
        },
        "dns_iran_only": {
          "type": "boolean",
          "description": "True when the domain's nameservers are only reachable from within Iran"
        }
      }
    }
  }
}
